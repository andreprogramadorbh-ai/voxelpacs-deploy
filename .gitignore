# =============================================================================
# VOXEL PACS DEPLOY — .gitignore
# =============================================================================

# Variáveis de ambiente (NUNCA versionar)
.env
.env.local
.env.production

# Volumes Docker (dados gerados em runtime)
storage/dicom/
postgres/data/
logs/
backups/

# Configurações geradas dinamicamente pelo install.sh
# (contêm senhas — geradas a partir do .env)
orthanc/credentials.json
orthanc/postgresql.json

# SSL (gerado pelo Certbot)
ssl/

# Temporários
*.tmp
*.bak
*.swp
*~
.DS_Store
