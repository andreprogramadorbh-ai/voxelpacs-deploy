###############################################################
# VOXEL PACS DEPLOY — .env.example
# Copie para .env e preencha os valores reais:
#   cp .env.example .env && nano .env
###############################################################

###############################################################
# DOMÍNIO
###############################################################
DOMAIN=view.voxelpacs.com.br

###############################################################
# SSL
###############################################################
GENERATE_SSL=yes
CERTBOT_EMAIL=andre@voxelpacs.com.br

###############################################################
# OHIF VIEWER
# Versão fixa — altere aqui para atualizar o OHIF
# Não usar latest em produção
###############################################################
OHIF_NAME=VOXEL PACS
OHIF_PORT=3000
OHIF_VERSION=v3.12.5

###############################################################
# ORTHANC
# Servidor DICOM — acesso apenas via proxy Nginx
# NUNCA expor porta 8042 ou 4242 externamente
###############################################################
ORTHANC_USERNAME=vivere_admin
ORTHANC_PASSWORD=ChangeMe
ORTHANC_AET=ORTHANCPACS

###############################################################
# DICOMWEB (rotas via proxy Nginx — sem IP, sem porta)
###############################################################
QIDO_ROOT=/dicom-web
WADO_ROOT=/dicom-web
WADO_URI_ROOT=/wado

###############################################################
# POSTGRESQL
# Banco de dados local (container Docker)
# Armazena: índices Orthanc + dados da API VOXEL PACS
###############################################################
POSTGRES_DB=voxelpacs
POSTGRES_USER=voxelpacs
POSTGRES_PASSWORD=ChangeMe_GenerateStrongPassword

###############################################################
# API VOXEL PACS
# Coração do sistema: auth, RBAC, tokens, auditoria, RIS, ERP
###############################################################
JWT_SECRET=ChangeMe_GenerateWithOpenSSL_rand_hex_32
APP_ENV=production
API_PORT=8080

###############################################################
# NGINX
###############################################################
NGINX_PORT=80

###############################################################
# DOCKER
###############################################################
COMPOSE_PROJECT_NAME=voxelpacs

###############################################################
# LOGS
###############################################################
TIMEZONE=America/Sao_Paulo

###############################################################
# BACKUP
# Backup separado: banco + storage + configs
###############################################################
BACKUP_DIR=./backups

###############################################################
# EVOLUÇÃO FUTURA
# Habilitar quando necessário
###############################################################
REDIS_ENABLED=no
# REDIS_URL=redis://redis:6379

###############################################################
# FIM
###############################################################
