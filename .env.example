# =============================================================================
# VOXEL PACS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA faça commit do arquivo .env no Git.
# =============================================================================

# --- Domínio e SSL ---
# O domínio ou subdomínio que aponta para este servidor.
# Exemplo: view.voxelpacs.com.br
DOMAIN=view.seudominio.com.br

# E-mail para notificações de renovação do certificado SSL (Let's Encrypt).
CERTBOT_EMAIL=seuemail@seudominio.com.br

# Gerar certificado SSL automaticamente durante a instalação?
# Valores: yes | no
GENERATE_SSL=yes

# --- Servidor Orthanc (PACS Remoto) ---
# Endereço IP ou domínio do servidor Orthanc.
ORTHANC_HOST=192.168.1.100

# Porta HTTP do Orthanc (padrão: 8042).
ORTHANC_PORT=8042

# Protocolo de conexão com o Orthanc.
# Valores: http | https
ORTHANC_PROTOCOL=http

# --- Backup ---
# Diretório onde os arquivos de backup serão armazenados.
# Pode ser um caminho absoluto ou relativo ao diretório do repositório.
BACKUP_DIR=./backups
