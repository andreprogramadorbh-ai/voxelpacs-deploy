###############################################################
# VOXEL PACS DEPLOY — .env.example
# Copie para .env e preencha os valores reais:
#   cp .env.example .env && nano .env
###############################################################

###############################################################
# DOMÍNIO
###############################################################
DOMAIN=view.voxelpacs.com.br

###############################################################
# SSL
###############################################################
GENERATE_SSL=yes
CERTBOT_EMAIL=andre@voxelpacs.com.br

###############################################################
# OHIF VIEWER
# Versão FIXA — não usar latest em produção
# Para atualizar: altere aqui, teste e faça commit
###############################################################
OHIF_NAME=VOXEL PACS
OHIF_PORT=3000
OHIF_VERSION=v3.12.5

###############################################################
# ORTHANC
# Servidor DICOM — acesso apenas via proxy Nginx
# NUNCA expor porta 8042 ou 4242 externamente
###############################################################
ORTHANC_USERNAME=vivere_admin
ORTHANC_PASSWORD=ChangeMe
ORTHANC_AET=VOXELSRVPACS

###############################################################
# DICOMWEB (rotas via proxy Nginx — sem IP, sem porta)
###############################################################
QIDO_ROOT=/dicom-web
WADO_ROOT=/dicom-web
WADO_URI_ROOT=/wado

###############################################################
# MYSQL 8.0
# Banco de dados da API VOXEL PACS (container Docker)
# Migrations executadas automaticamente na primeira inicialização
###############################################################
DB_DATABASE=voxel_pacs
DB_USERNAME=voxelpacs_user
DB_PASSWORD=ChangeMe_GenerateStrongPassword
MYSQL_ROOT_PASSWORD=ChangeMe_GenerateStrongRootPassword

###############################################################
# API VOXEL PACS (Sistema PHP 8.1)
# Código-fonte em api/ (submódulo git → andreprogramadorbh-ai/voxelpacs)
###############################################################
APP_ENV=production
APP_SECRET=ChangeMe_GenerateWith_openssl_rand_hex_32
API_PORT=8080

# E-mail (opcional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@voxelpacs.com.br

###############################################################
# NGINX
###############################################################
NGINX_PORT=80

###############################################################
# DOCKER
###############################################################
COMPOSE_PROJECT_NAME=voxelpacs

###############################################################
# LOGS
###############################################################
TIMEZONE=America/Sao_Paulo

###############################################################
# BACKUP
###############################################################
BACKUP_DIR=./backups

###############################################################
# FIM
###############################################################
